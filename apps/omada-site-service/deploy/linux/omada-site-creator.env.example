NODE_ENV=production
OMADA_SITE_CREATOR_HOST=127.0.0.1
OMADA_SITE_CREATOR_PORT=3210
OMADA_SITE_CREATOR_DATA_DIR=/var/lib/omada-site-creator/data
OMADA_SITE_CREATOR_WEBHOOK_TOKEN=replace-with-a-long-random-secret
OMADA_SITE_CREATOR_HEADLESS=true
OMADA_SITE_CREATOR_BROWSER_CHANNEL=chromium

# TP-Link cloud account for automatic login when the saved session expires.
OMADA_SITE_CREATOR_CLOUD_EMAIL=replace-with-your-tplink-email@example.com
OMADA_SITE_CREATOR_CLOUD_PASSWORD=replace-with-your-tplink-password

# Optional default device account for site creation.
OMADA_SITE_CREATOR_DEVICE_USERNAME=admin
OMADA_SITE_CREATOR_DEVICE_PASSWORD=replace-with-your-device-password
